#
# For a description of the syntax of this configuration file,
# see the file kconfig-language.txt in the NuttX tools repository.
#

config EXAMPLES_CAMERA_MSN2
	tristate "\camera mission MSN2 example"
	default n
	---help---
		Enable the \"Camera MSN2\" example

if EXAMPLES_CAMERA_MSN2

config EXAMPLES_CAMERA_MSN2_PROGNAME
	string "Program name"
	default "camera_MSN2"
	---help---
		This is the name of the program that will be used when the NSH ELF
		program is installed.

config EXAMPLES_CAMERA_MSN2_PRIORITY
	int "Camera MSN2 task priority"
	default 100

config EXAMPLES_CAMERA_MSN2_STACKSIZE
	int "Camera MSN2 stack size"
	default DEFAULT_TASK_STACKSIZE

endif

